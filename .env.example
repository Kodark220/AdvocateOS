# AdvocateOS — Backend & Agent Environment Variables
# Copy this to .env and fill in your values

# Contract address (default: current Bradbury testnet deployment)
AOS_CONTRACT=0xAE693Bbb157FAf221bc6F6f12766f494Ae99aef3

# Path to genlayer CLI (leave empty to auto-detect from PATH)
AOS_GL_PATH=

# Flask secret key (generate a random string for production)
AOS_SECRET_KEY=change-me-to-a-random-string

# Allowed CORS origins (comma-separated, e.g. https://your-app.vercel.app)
AOS_CORS_ORIGINS=*

# Timeouts (seconds)
AOS_WRITE_TIMEOUT=600
AOS_READ_TIMEOUT=60

# Agent intervals (seconds)
AOS_SCAN_INTERVAL=3600
AOS_CASE_CHECK_INTERVAL=1800
